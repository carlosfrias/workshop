{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trading-journal://schemas/future-schema.json",
  "title": "Future Trade Schema",
  "description": "Futures trade with contract specs lookup, point value, tick calculator (DTI + LS Futures features)",
  "type": "object",
  "properties": {
    "tradeId": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{4}-[A-Z0-9]+-[0-9]{4}-[0-9]{2}-(LONG|SHORT)$",
      "description": "Unique trade ID: YYYYMMDD-HHMM-SYMBOL-YEAR-MONTH-DIRECTION"
    },
    "symbol": {
      "type": "string",
      "description": "Futures root symbol (e.g., ES, NQ, CL)"
    },
    "contractMonth": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "Contract month (YYYY-MM format)"
    },
    "fullSymbol": {
      "type": "string",
      "description": "Full futures symbol (e.g., ESZ2026)"
    },
    "direction": {
      "type": "string",
      "enum": ["LONG", "SHORT"],
      "description": "Trade direction"
    },
    "status": {
      "type": "string",
      "enum": ["OPEN", "PARTIAL", "CLOSED"],
      "description": "Current trade status"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Trade entry timestamp (UTC)"
    },
    "contractSpecId": {
      "type": "string",
      "description": "Reference to market lookup table for contract specs (LS Futures feature)"
    },
    "pointValue": {
      "type": "number",
      "minimum": 0,
      "description": "Dollar value per point (from lookup or inline)"
    },
    "tickSize": {
      "type": "number",
      "minimum": 0,
      "description": "Minimum price fluctuation"
    },
    "tickValue": {
      "type": "number",
      "minimum": 0,
      "description": "Dollar value per tick (DTI calculator feature)"
    },
    "contractSize": {
      "type": "number",
      "description": "Contract size (units of underlying)"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {"type": "number", "minimum": 0},
          "contracts": {"type": "integer", "minimum": 1},
          "timestamp": {"type": "string", "format": "date-time"},
          "commission": {"type": "number", "minimum": 0}
        },
        "required": ["price", "contracts", "timestamp"]
      },
      "description": "Multiple entries for scaling"
    },
    "exits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {"type": "number", "minimum": 0},
          "contracts": {"type": "integer", "minimum": 1},
          "timestamp": {"type": "string", "format": "date-time"},
          "commission": {"type": "number", "minimum": 0},
          "pnl": {"type": "number"},
          "rMultiple": {"type": "number"}
        },
        "required": ["price", "contracts", "timestamp"]
      },
      "description": "Multiple exits for partial closes"
    },
    "contracts": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of futures contracts"
    },
    "averageEntryPrice": {
      "type": "number",
      "minimum": 0,
      "description": "Weighted average entry price"
    },
    "averageExitPrice": {
      "type": "number",
      "minimum": 0,
      "description": "Weighted average exit price"
    },
    "stopLoss": {
      "type": "number",
      "minimum": 0,
      "description": "Stop loss price level"
    },
    "stopLossHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {"type": "number"},
          "timestamp": {"type": "string", "format": "date-time"},
          "rationale": {"type": "string"}
        },
        "required": ["price", "timestamp"]
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "targetNumber": {"type": "integer", "minimum": 1, "maximum": 3},
          "price": {"type": "number"},
          "contractsPercent": {"type": "number", "minimum": 0, "maximum": 100},
          "filled": {"type": "boolean", "default": false}
        },
        "required": ["targetNumber", "price"]
      },
      "minItems": 1,
      "maxItems": 3,
      "description": "3-target scaling system"
    },
    "commission": {
      "type": "number",
      "minimum": 0,
      "description": "Total commission paid"
    },
    "commissionPerContract": {
      "type": "number",
      "minimum": 0,
      "description": "Commission per contract (from lookup)"
    },
    "marginRequirement": {
      "type": "number",
      "minimum": 0,
      "description": "Initial margin requirement per contract (from lookup)"
    },
    "totalMarginUsed": {
      "type": "number",
      "minimum": 0,
      "description": "Total margin used for this position"
    },
    "realizedPnL": {
      "type": "number",
      "description": "Realized P&L on closed portion"
    },
    "realizedR": {
      "type": "number",
      "description": "Realized R-multiple"
    },
    "unrealizedPnL": {
      "type": "number",
      "description": "Unrealized P&L on open portion"
    },
    "unrealizedR": {
      "type": "number",
      "description": "Unrealized R-multiple"
    },
    "riskReward": {
      "type": "string",
      "description": "Risk-reward ratio"
    },
    "riskAmount": {
      "type": "number",
      "description": "Dollar amount at risk"
    },
    "entryRationale": {
      "type": "string",
      "description": "Entry rationale"
    },
    "exitRationale": {
      "type": "string",
      "description": "Exit rationale"
    },
    "setupType": {
      "type": "string",
      "description": "Trade setup type"
    },
    "blockId": {
      "type": "string",
      "description": "Block identifier for block analysis (DTI feature)"
    },
    "blockNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential block number"
    },
    "timeInDays": {
      "type": "number",
      "description": "Trade length in days (LS feature)"
    },
    "journalNote": {
      "type": "string",
      "description": "Link to journal note"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["ENTRY", "ADJUST_STOP", "SCALE_IN", "SCALE_OUT", "CLOSE", "TRAIL", "ROLL"]
          },
          "timestamp": {"type": "string", "format": "date-time"},
          "details": {"type": "object"}
        },
        "required": ["action", "timestamp"]
      }
    }
  },
  "required": [
    "tradeId",
    "symbol",
    "direction",
    "status",
    "timestamp",
    "contracts"
  ],
  "calculations": {
    "tickValue": "tickSize * pointValue",
    "realizedPnL": "sum((exitPrice - entryPrice) * pointValue * contracts) for LONG, inverse for SHORT",
    "unrealizedPnL": "(currentPrice - averageEntryPrice) * pointValue * contracts for LONG, inverse for SHORT",
    "totalMarginUsed": "marginRequirement * contracts"
  }
}
