#!/bin/bash
#
# DuckDNS Dynamic DNS Updater
# Installed by Ansible (duckdns-updater role)
# Runs via cron every 5 minutes

set -e

DOMAIN="{{ duckdns_domain }}"
TOKEN="{{ duckdns_token }}"

RESULT=$(curl -fsSL "https://www.duckdns.org/update?domains=${DOMAIN}&token=${TOKEN}&ip=" 2>/dev/null)

if [ "$RESULT" = "OK" ]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] DuckDNS OK: ${DOMAIN}.duckdns.org"
    exit 0
else
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] DuckDNS FAILED: ${RESULT}"
    exit 1
fi
